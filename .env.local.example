# NucleuX Academy - Environment Variables
# Copy this file to .env.local and fill in your values

# ------------------------------------------------------------
# Core app runtime (required)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ------------------------------------------------------------
# Optional but commonly required for scripts/admin workflows
# ------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_SEED_EMAIL=admin@nucleux.academy
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NAME=Admin User

# ------------------------------------------------------------
# AI providers
# ------------------------------------------------------------
# Required for /api/chat
ANTHROPIC_API_KEY=your-anthropic-api-key

# Required for /api/speech/stt and /api/speech/tts
SARVAM_API_KEY=your-sarvam-api-key

# ------------------------------------------------------------
# Optional e2e/smoke test variables
# ------------------------------------------------------------
E2E_BASE_URL=http://127.0.0.1:3000
E2E_EMAIL=
E2E_PASSWORD=

# ------------------------------------------------------------
# Optional marketing screenshot script variables
# ------------------------------------------------------------
BASE_URL=http://localhost:3100
DEMO_EMAIL=
DEMO_PASSWORD=
