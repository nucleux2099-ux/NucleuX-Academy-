# NucleuX Academy - Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: For server-side operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Vyasa ATOM Source Library path override for sync-vyasa
VYASA_ATOM_LIBRARY_PATH=/Users/adityachandrabhatla/clawd-vyasa/data/output

# Optional: Protect POST /api/atom/sources/sync-vyasa with shared token
ATOM_VYASA_SYNC_TOKEN=replace-with-strong-token

# Optional: Phase 2 scaffold feature flags (default false)
FEATURE_ATOM_PHASE2_SCAFFOLD=false
FEATURE_ATOM_INTENT_CARD=false
FEATURE_ATOM_QUICK_START_SCHEMA=false
