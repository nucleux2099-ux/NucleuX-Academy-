{
  "name": "nucleux-temp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "tsx scripts/validate-cbme-links.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:stabilization": "eslint \"src/app/(app)/desk/page.tsx\" \"src/app/(app)/analytics/page.tsx\" \"src/app/(app)/profile/page.tsx\" \"src/app/(app)/settings/page.tsx\" \"src/app/(app)/mcqs/page.tsx\" \"src/components/api-state-boundary.tsx\" \"src/lib/api/hooks.ts\" \"src/app/api/analytics/route.ts\"",
    "test:smoke": "node scripts/smoke-e2e.mjs",
    "test:atom:dedup": "tsx --test src/components/atom/chatEventDedup.test.ts",
    "test:atom:route-smoke": "tsx --test src/app/__tests__/atom-route-smoke.test.ts",
    "test:atom:nightly-gates": "npm run -s typecheck && npm run -s lint && npm run -s test:atom:route-smoke && npm run -s test:atom:dedup && npm run -s build",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "content:validate": "tsx scripts/validate-content.ts",
    "validate:cbme": "tsx scripts/validate-cbme-links.ts",
    "atom:sources:sync": "tsx scripts/sync-atom-source-availability.ts",
    "atom:sources:sync-vyasa": "tsx scripts/sync-vyasa-atom-sources.ts",
    "atom:sources:validate-sync-candidates": "tsx scripts/validate-vyasa-sync-candidates.ts",
    "atom:scope:audit": "tsx scripts/atom-scope-migration-audit.ts",
    "atom:rollup:hourly": "tsx scripts/atom-telemetry-rollup-job.ts --granularity hour --window-hours 2",
    "atom:rollup:daily": "tsx scripts/atom-telemetry-rollup-job.ts --granularity day --window-hours 26",
    "atom:retention:dry-run": "tsx scripts/atom-telemetry-retention-job.ts",
    "atom:retention:enforce": "tsx scripts/atom-telemetry-retention-job.ts --enforce",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@excalidraw/excalidraw": "^0.18.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tailwindcss/typography": "^0.5.19",
    "ai": "^6.0.86",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.33.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.12.2",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shepherd.js": "^14.5.1",
    "tailwind-merge": "^3.4.0",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
