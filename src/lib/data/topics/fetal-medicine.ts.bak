        { id: 'fas-6', question: 'What structure should be visualized to rule out holoprosencephaly?', answer: 'Cavum septum pellucidum (CSP) - absent in holoprosencephaly', difficulty: 3 }
      ],
      cases: [
        {
          id: 'fas-case-1',
          title: 'Lemon and Banana Signs',
          presentation: '20-week anomaly scan shows "lemon-shaped" skull on BPD view and curved cerebellum. Mild ventriculomegaly (12 mm) noted. Spine examination shows a lumbar defect.',
          questions: [
            { question: 'What is the diagnosis?', answer: 'Open spina bifida (myelomeningocele) with Chiari II malformation' },
            { question: 'What causes these cranial findings?', answer: 'Hindbrain herniation (Chiari II) pulls cerebellum down (banana sign) and alters intracranial pressure (lemon sign)' },
            { question: 'What are the next steps?', answer: 'Detailed scan, amniocentesis for karyotype and AFP/AChE, MRI for detailed evaluation, multidisciplinary counseling, discuss options including fetal surgery' }
          ],
