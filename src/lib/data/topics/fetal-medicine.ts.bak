        },
        {
          id: 'nipt-case-2',
          title: 'No-Call NIPT Result',
          presentation: 'A 32-year-old G2P1 with BMI 42 has NIPT at 12 weeks. The lab reports "no result due to low fetal fraction" (3.2%).',
          questions: [
            { question: 'Why did this occur?', answer: 'High BMI increases maternal cfDNA from adipose tissue, diluting fetal fraction below the 4% threshold' },
            { question: 'What are the options?', answer: '1) Repeat NIPT in 2 weeks (fetal fraction increases with GA), 2) Invasive testing, 3) Serum screening' },
            { question: 'Is there any additional significance to no-call results?', answer: 'Yes - no-call results are associated with higher aneuploidy risk, particularly T13, T18' }
          ],
          keyLearning: [
            'High BMI is a common cause of low fetal fraction',
