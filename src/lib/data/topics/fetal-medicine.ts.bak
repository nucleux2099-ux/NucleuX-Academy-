        { id: 'fas-2', question: 'What do the lemon and banana signs indicate?', answer: 'Open spina bifida with Chiari II malformation', difficulty: 2 },
        { id: 'fas-3', question: 'What defines ventriculomegaly?', answer: 'Atrial width >10 mm (10-15 mm = mild, >15 mm = severe)', difficulty: 2 },
        { id: 'fas-4', question: 'What percentage of cardiac anomalies does the 4-chamber view detect?', answer: '40-50% - outflow tract views essential for higher detection', difficulty: 3 },
