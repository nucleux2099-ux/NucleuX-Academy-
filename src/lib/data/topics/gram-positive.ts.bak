    ],
    
    retrievalCards: [
      {
        id: 'gp-algo-1',
        question: 'Draw the complete GP cocci identification algorithm',
        answer: 'GP Cocci → CATALASE\n- Positive → Staphylococcus → COAGULASE\n  - Positive → S. aureus\n  - Negative → CoNS → NOVOBIOCIN\n    - Resistant → S. saprophyticus\n    - Sensitive → S. epidermidis\n- Negative → Streptococcus → HEMOLYSIS\n  - β: Bacitracin/PYR (GAS), CAMP (GBS)\n  - α: Optochin/Bile (Pneumo vs Viridans)\n  - γ: Bile esculin + 6.5% NaCl (Enterococcus)',
