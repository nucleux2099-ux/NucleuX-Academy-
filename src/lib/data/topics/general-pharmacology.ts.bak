      ],
      cases: [
        {
          id: 'rec-case-1',
          title: 'Beta-Blocker Rebound',
          presentation: 'A 55-year-old man with hypertension has been on propranolol for 3 years. He suddenly stops his medication and 2 days later develops severe chest pain and tachycardia (HR 140). ECG shows ischemic changes.',
