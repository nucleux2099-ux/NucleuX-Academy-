      ],
      retrievalCards: [
        { id: 'ang-1', question: 'How do nitrates reduce myocardial O₂ demand?', answer: 'Primarily by venodilation → ↓ preload → ↓ ventricular wall tension', difficulty: 2 },
        { id: 'ang-2', question: 'Why are nitrates contraindicated with PDE-5 inhibitors?', answer: 'Both increase cGMP → synergistic vasodilation → severe hypotension', difficulty: 2 },
        { id: 'ang-3', question: 'How is nitrate tolerance prevented?', answer: '10-12 hour nitrate-free interval daily (usually overnight)', difficulty: 1 },
        { id: 'ang-4', question: 'Why are β-blockers potentially harmful in vasospastic angina?', answer: 'Block β2 vasodilation → unopposed α-mediated coronary vasoconstriction', difficulty: 3 },
        { id: 'ang-5', question: 'What is the mechanism of ranolazine?', answer: 'Blocks late Na⁺ current → reduces Na⁺/Ca²⁺ overload → improves diastolic relaxation', difficulty: 3 },
        { id: 'ang-6', question: 'What visual side effect is characteristic of ivabradine?', answer: 'Phosphenes (luminous phenomena) - flashes of light', difficulty: 1 },
        { id: 'ang-7', question: 'What is the unique ADR of nicorandil?', answer: 'Oral and GI ulceration', difficulty: 2 }
      ],
      cases: [
        {
          id: 'ang-case-1',
          title: 'Severe Hypotension After Chest Pain',
          presentation: 'A 62-year-old man with erectile dysfunction took sildenafil last night. This morning, he developed chest pain and took his wife\'s sublingual NTG. He is now hypotensive (70/40), diaphoretic, and confused.',
          questions: [
            { question: 'What is the diagnosis?', answer: 'Severe hypotension from nitrate + PDE-5 inhibitor interaction' },
